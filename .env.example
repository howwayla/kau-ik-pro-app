# ── Nova Pro server providers ────────────────────────────────────────
# Providers default to mock (simulated quotes & paper trading, no
# credentials needed). Switch to real providers once you have keys.
# Copy this file to `.env` and fill in values. NEVER commit `.env`.
MARKET_PROVIDER=mock   # mock | fugle
TRADE_PROVIDER=mock    # mock | fubon | nova
PORT=8080

# ── Fugle market data (MARKET_PROVIDER=fugle) ────────────────────────
# Apply for an API key at https://developer.fugle.tw/
FUGLE_API_KEY=

# ── Broker login ─────────────────────────────────────────────────────
# Both Fubon NEO (fubon-neo) and Taishin Nova (taishin-sdk) log in with
# national ID + password + certificate (.pfx/.p12) + certificate password.
# Their SDKs are downloaded manually as .tgz — drop them in server/vendor/.
#
# The dashboard「券商」switcher reads per-broker credentials so you can hot-
# swap without restarting (credentials may also be typed once in the UI and
# are then saved to gitignored server/data/config.json):
# FUBON_ID_NO=            # or FUBON_NATIONAL_ID
# FUBON_PASSWORD=         # or use FUBON_API_KEY (v2.2.7+ apikeyLogin)
# FUBON_API_KEY=
# FUBON_CERT_PATH=
# FUBON_CERT_PASS=
# NOVA_ID_NO=             # or NOVA_NATIONAL_ID
# NOVA_PASSWORD=          # or NOVA_ACCOUNT_PASS
# NOVA_CERT_PATH=
# NOVA_CERT_PASS=
# NOVA_API_URL=           # test environment only; production is built in
# ESUN_ACCOUNT=           # 玉山證券帳號（884 開頭）, or ESUN_AID
# ESUN_PASSWORD=
# ESUN_API_KEY=
# ESUN_API_SECRET=
# ESUN_CERT_PATH=         # .p12 absolute path
# ESUN_CERT_PASS=
# ESUN_API_URL=           # or ESUN_ENTRY; production is built in
#
# Generic BROKER_* applies to the boot-time TRADE_PROVIDER only:
BROKER_ID_NO=
BROKER_PASSWORD=
# Fubon only: log in with an API key (v2.2.7+ apikeyLogin) instead of the
# account password — certificate is still required.
BROKER_API_KEY=
BROKER_CERT_PATH=
BROKER_CERT_PASS=
# Optional broker API base URL override. Nova defaults to the production
# endpoint https://fugletrade.tssco.com.tw — set this only for the test
# environment. (Fubon ignores this.)
# BROKER_API_URL=

# ── Frontend (optional) ──────────────────────────────────────────────
# Override REST/SSE base URL for a remote server.
# Leave unset when using the dev proxy.
# VITE_API_BASE=http://127.0.0.1:8080
