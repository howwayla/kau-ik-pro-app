# ── Nova Pro server providers ────────────────────────────────────────
# Providers default to mock (simulated quotes & paper trading, no
# credentials needed). Switch to real providers once you have keys.
# Copy this file to `.env` and fill in values. NEVER commit `.env`.
MARKET_PROVIDER=mock   # mock | fugle
TRADE_PROVIDER=mock    # mock | fubon | nova
PORT=8080

# ── Fugle market data (MARKET_PROVIDER=fugle) ────────────────────────
# Apply for an API key at https://developer.fugle.tw/
FUGLE_API_KEY=

# ── Broker login (TRADE_PROVIDER=fubon or nova) ──────────────────────
# Both Fubon NEO (fubon-neo) and Taishin Nova (taishin-sdk) log in with
# national ID + password + certificate (.pfx) + certificate password.
# Their SDKs are downloaded manually as .tgz — drop them in server/vendor/.
BROKER_ID_NO=
BROKER_PASSWORD=
BROKER_CERT_PATH=
BROKER_CERT_PASS=

# ── Frontend (optional) ──────────────────────────────────────────────
# Override REST/SSE base URL for a remote server.
# Leave unset when using the dev proxy.
# VITE_API_BASE=http://127.0.0.1:8080
